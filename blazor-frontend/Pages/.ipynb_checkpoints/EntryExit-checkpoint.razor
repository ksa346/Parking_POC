@using BlazorParking.Services.State
@using BlazorParking.Services
@page "/"
@implements IDisposable
@inject OccupancyWebSocketService WsService
@inject EntryExitState Params
@inject ConfigurationState config
@inject IConfiguration Configuration
@inject ParkingService Api
@inject ILogger<EntryExit> Logger

<PageTitle>Car Detection — Cornerstone Garage</PageTitle>

<!-- KPI Cards -->
<div class="kpi-cards-container">
    <div class="kpi-card kpi-card-total">
        <div class="kpi-header" style="background-color: #0033A0;">
            <div class="kpi-icon">🅿️</div>
            <div class="kpi-badge">Garage Capacity</div>
        </div>
        <div class="kpi-content">
            <div class="kpi-number">@EntryExitTotalLotCount</div>
            <div class="kpi-title">Total Parking Spaces (General + ADA + EV)</div>
            <div class="kpi-bar-container">
                <div class="kpi-bar" style="background-color: #0033A0; width: 100%;"></div>
            </div>
            <div class="kpi-footer">
                <div class="kpi-footer-left">Available/Total</div>
                <div class="kpi-footer-right">@CurrentAvailable / @EntryExitTotalLotCount</div>
            </div>
        </div>
    </div>

    <div class="kpi-card kpi-card-general">
        <div class="kpi-header" style="background-color: #1A7F37;">
            <div class="kpi-icon">🅿️</div>
            <div class="kpi-badge">@(config.GeneralSpots > 0 ? (int)Math.Round((decimal)(config.GeneralSpots - Params.GeneralOccupied) / config.GeneralSpots * 100) : 0)%</div>
        </div>
        <div class="kpi-content">
            <div class="kpi-number">@(config.GeneralSpots - Params.GeneralOccupied)</div>
            <div class="kpi-title">General Spaces Available</div>
            <div class="kpi-bar-container">
                <div class="kpi-bar" style="background-color: #1A7F37; width: @(config.GeneralSpots > 0 ? (int)Math.Round((decimal)(config.GeneralSpots - Params.GeneralOccupied) / config.GeneralSpots * 100) : 0)%;"></div>
            </div>
            <div class="kpi-footer">
                <div class="kpi-footer-left">Available/Total</div>
                <div class="kpi-footer-right">@(config.GeneralSpots - Params.GeneralOccupied) / @config.GeneralSpots</div>
            </div>
        </div>
    </div>

    <div class="kpi-card kpi-card-ada">
        <div class="kpi-header" style="background-color: #0055CC;">
            <div class="kpi-icon">♿</div>
            <div class="kpi-badge">@(config.AdaSpots > 0 ? (int)Math.Round((decimal)(config.AdaSpots - Params.AdaOccupied) / config.AdaSpots * 100) : 0)%</div>
        </div>
        <div class="kpi-content">
            <div class="kpi-number">@(config.AdaSpots - Params.AdaOccupied)</div>
            <div class="kpi-title">ADA Spaces Available</div>
            <div class="kpi-bar-container">
                <div class="kpi-bar" style="background-color: #0055CC; width: @(config.AdaSpots > 0 ? (int)Math.Round((decimal)(config.AdaSpots - Params.AdaOccupied) / config.AdaSpots * 100) : 0)%;"></div>
            </div>
            <div class="kpi-footer">
                <div class="kpi-footer-left">Available/Total</div>
                <div class="kpi-footer-right">@(config.AdaSpots - Params.AdaOccupied) / @config.AdaSpots</div>
            </div>
        </div>
    </div>

    <div class="kpi-card kpi-card-ev">
        <div class="kpi-header" style="background-color: #166534;">
            <div class="kpi-icon">🔌</div>
            <div class="kpi-badge">@(config.EvSpots > 0 ? (int)Math.Round((decimal)(config.EvSpots - Params.EvOccupied) / config.EvSpots * 100) : 0)%</div>
        </div>
        <div class="kpi-content">
            <div class="kpi-number">@(config.EvSpots - Params.EvOccupied)</div>
            <div class="kpi-title">EV Charging Spaces Available</div>
            <div class="kpi-bar-container">
                <div class="kpi-bar" style="background-color: #166534; width: @(config.EvSpots > 0 ? (int)Math.Round((decimal)(config.EvSpots - Params.EvOccupied) / config.EvSpots * 100) : 0)%;"></div>
            </div>
            <div class="kpi-footer">
                <div class="kpi-footer-left">Available/Total</div>
                <div class="kpi-footer-right">@(config.EvSpots - Params.EvOccupied) / @config.EvSpots</div>
            </div>
        </div>
    </div>
</div>

